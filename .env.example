# Required for CDR analysis
ANTHROPIC_API_KEY=sk-ant-...

# Optional: HubSpot Forms API (submit lead to form)
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=

# Optional: Generic webhook URL (POST payload with summary + contact)
CDR_LEAD_WEBHOOK_URL=

# Optional: net2phone AI build configuration for the embedded onboarding flow
NET2PHONE_SIGN_UP_URL=
NET2PHONE_AUTH_URL=https://auth-qa.net2phone.com
NET2PHONE_VA_API_URL=https://api-qa.n2p.io/v2/virtual-agent
