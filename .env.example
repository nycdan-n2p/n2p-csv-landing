# Required for CDR analysis
ANTHROPIC_API_KEY=sk-ant-...

# Optional: HubSpot Forms API (submit lead to form)
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=

# Optional: Generic webhook URL (POST payload with summary + contact)
CDR_LEAD_WEBHOOK_URL=

# Optional: Flex app URL for redirect after form submit (default: https://flex.net2phone.com)
NEXT_PUBLIC_FLEX_APP_URL=https://flex.net2phone.com
