# Required for CDR analysis
ANTHROPIC_API_KEY=sk-ant-...

# Optional: reCAPTCHA for embedded email/phone verification
NEXT_PUBLIC_RECAPTCHA_SITE=
RECAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_ALLOWED_HOSTNAMES=

# Optional: HubSpot Forms API (submit lead to form)
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=

# Optional: Generic webhook URL (POST payload with summary + contact)
CDR_LEAD_WEBHOOK_URL=

# Optional: net2phone AI build configuration for the embedded onboarding flow
NET2PHONE_SIGN_UP_URL=
NET2PHONE_AUTH_URL=https://auth-qa.net2phone.com
NET2PHONE_VA_API_URL=https://api-qa.n2p.io/v2/virtual-agent

# Optional: OAuth / SSO — "I use net2phone" one-click connect path
# Register a client in the net2phone IdentityServer (auth.net2phone.com) with:
#   - grant_type: authorization_code
#   - PKCE: S256
#   - redirect_uri: https://<your-domain>/api/auth/net2phone/callback
#   - scopes: openid profile (add any CDR-specific scope if required)
NET2PHONE_OAUTH_CLIENT_ID=
NET2PHONE_OAUTH_CLIENT_SECRET=      # leave blank for public/PKCE-only clients
NET2PHONE_APP_API_URL=https://app.net2phone.com    # base URL for the CDR download API
NEXT_PUBLIC_BASE_URL=https://your-domain.com       # used to build the OAuth redirect URI
CDR_SESSION_SECRET=                                # 32+ random chars — openssl rand -hex 32

# Optional: Twilio Verify for phone confirmation
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
